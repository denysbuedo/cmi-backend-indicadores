        {
          "name": "Crear Fuente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"API GitHub\",\n  \"description\": \"Conexión a API de GitHub para métricas\",\n  \"endpoint\": \"https://api.github.com/repos/{owner}/{repo}/stats\",\n  \"method\": \"GET\",\n  \"headers\": {\n    \"Authorization\": \"Bearer {{TOKEN}}\"\n  },\n  \"timeout\": 5000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sources",
              "host": ["{{baseUrl}}"],
              "path": ["sources"]
            },
            "description": "Crea una nueva fuente de datos externa (API, webhook, etc.)."
          },
