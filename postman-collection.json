    {
      "name": "🔗 Fuentes de Datos",
      "item": [
        {
          "name": "Listar Fuentes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/sources",
              "host": ["{{baseUrl}}"],
              "path": ["sources"]
            },
            "description": "Lista todas las fuentes de datos configuradas."
          },
          "response": []
