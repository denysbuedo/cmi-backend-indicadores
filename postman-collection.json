              "path": ["health"]
            },
            "description": "Verifica que el servidor esté funcionando."
          },
          "response": []
        },
        {
          "name": "Obtener Tenant ID (Post-Seed)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://console.cloud.google.com/sql/instances",
              "host": ["console.cloud.google.com"],
              "path": ["sql", "instances"]
            },
            "description": "Después de ejecutar el seed, consulta la BD para obtener el UUID del tenant 'MES'. Actualiza la variable {{tenantId}} con ese valor."
